# ============================================
# Cloud Functions — Environment Variables
# ============================================
# These are SERVER-SIDE secrets. Never expose in frontend code.

# Shopify Integration (future)
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# Google Ads (future)
GOOGLE_ADS_CUSTOMER_ID=your_customer_id

# AI Integration (future)
OPENAI_API_KEY=your_openai_key

# Email/SMS (future)
SENDGRID_API_KEY=your_sendgrid_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Lead Capture Security
LEAD_CAPTURE_ALLOWED_ORIGINS=https://your-shopify-store.myshopify.com,https://your-custom-domain.com
