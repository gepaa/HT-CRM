# HT CRM — .gitignore
node_modules/
dist/

# ── Environment files ──────────────────────────────────────────
# Ignore real local secret/override files:
.env
.env.local
.env.*.local
# Explicitly ALLOW template and production placeholder files (no real secrets):
!.env.example
!.env.production
# Functions env
functions/.env
functions/.env.local
functions/.env.*.local
!functions/.env.example

# ── Service Account Keys (NEVER commit) ───────────────────────
serviceAccountKey.json
*-service-account.json
*serviceaccount*.json

# ── Firebase ──────────────────────────────────────────────────
.firebase/
functions/node_modules/
functions/lib/

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────
*.log
firebase-debug.log
firestore-debug.log
ui-debug.log
pubsub-debug.log

# ── Emulator data ─────────────────────────────────────────────
emulator-data/

# ── Vercel ────────────────────────────────────────────────────
.vercel
