rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check user role from custom claims
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return hasRole('admin');
    }

    // Helper: check if user is admin or sales rep
    function isAdminOrSalesRep() {
      return isAdmin() || hasRole('sales_rep');
    }

    // Leads — admin and sales_rep can read/write, viewer can read
    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdminOrSalesRep();
      allow delete: if isAdmin();

      // Lead events subcollection
      match /events/{eventId} {
        allow read: if isAuthenticated();
        allow write: if isAdminOrSalesRep();
      }

      // Lead notes subcollection
      match /notes/{noteId} {
        allow read: if isAuthenticated();
        allow write: if isAdminOrSalesRep();
      }
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdminOrSalesRep();
      allow delete: if isAdmin();
    }

    // Deals
    match /deals/{dealId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdminOrSalesRep();
      allow delete: if isAdmin();
    }

    // Settings — only admin can write, all authenticated can read
    match /settings/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Integration logs — read only for authenticated, write only by Cloud Functions (admin SDK)
    match /integrations_log/{logId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Users collection for CRM user profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    // Shopify webhook delivery receipts — admin SDK writes (bypass rules),
    // admin users can read for debugging, all others denied.
    match /shopify_webhook_deliveries/{deliveryId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
