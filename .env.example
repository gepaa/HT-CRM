# ============================================
# Garage Auto Supplies CRM — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# IMPORTANT: VITE_ prefixed vars are PUBLIC (bundled into the frontend).
# Never put secrets in VITE_ variables.

# Firebase Client Config (PUBLIC — safe to expose)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Runtime Mode
# true  = Auth/Firestore/Functions emulators and local function URL:
#         http://127.0.0.1:5001/<project>/<region>/<function>
# false = production Firebase services and cloud function URL:
#         https://<region>-<project>.cloudfunctions.net/<function>
VITE_USE_EMULATORS=true
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Optional override for direct HTTP function URLs.
# Example emulator override: http://127.0.0.1:5001/your-project/us-central1
# Example production override: https://us-central1-your-project.cloudfunctions.net
VITE_FUNCTIONS_BASE_URL=

# Optional override for routed API calls. Leave blank on Firebase Hosting.
# Example: https://your-firebase-hosting-domain.web.app/api
VITE_API_BASE_URL=

# App Settings
VITE_APP_NAME=Garage Auto Supplies CRM
VITE_APP_TIMEZONE=America/New_York
