# ============================================
# Garage Auto Supplies CRM — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# IMPORTANT: VITE_ prefixed vars are PUBLIC (bundled into the frontend).
# Never put secrets in VITE_ variables.

# Supabase Config (PUBLIC — safe to expose)
VITE_SUPABASE_URL=https://hublaayffajalhnmwpgp.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_lGXIZL0MdtgMcus9Vr5yvw_N1iVX5g2

# Supabase Server-side Service Role Key (SECRET — DO NOT EXPOSE IN FRONTEND)
# Used by Vercel Serverless Functions (/api/...) and scripts
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional override for API calls. Leave blank on Vercel deployment.
VITE_API_BASE_URL=/api

# App Settings
VITE_APP_NAME=Garage Auto Supplies CRM
VITE_APP_TIMEZONE=America/New_York

# Google Gemini AI Integration (Free Tier: gemini-1.5-flash)
# Get your free key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
